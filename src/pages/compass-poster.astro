---
import Layout from '../layouts/Layout.astro'

const title = 'Free Body Compass Poster — Craig Van'
const description = 'A visual food map that shows you exactly what to eat, what to test, and what to avoid. Free when you subscribe.'
const image = '/og-compass-poster.png'
const path = '/compass-poster'
---

<Layout title={title} description={description} image={image} path={path}>
  <main class="mx-auto max-w-2xl px-6 py-20 md:py-28">

    <section class="animate-fade-up">
      <a href="/" class="mb-12 inline-block font-mono text-xs tracking-[0.25em] text-muted uppercase transition-colors duration-300 hover:text-accent">Craig Van</a>

      <p class="mb-6 font-mono text-xs tracking-[0.25em] text-muted uppercase">Free poster</p>

      <div class="md:grid md:grid-cols-[1fr_auto] md:gap-10 md:items-start">
        <a
          href="#subscribe"
          aria-label="Jump to the sign-up form to get the poster"
          class="group mb-8 block w-[150px] mx-auto md:mx-0 md:mb-0 md:w-[200px] md:mt-1 md:shrink-0 md:col-start-2 md:row-start-1"
        >
          <div class="overflow-hidden rounded-md border border-border/80 shadow-[0_20px_40px_-20px_rgba(0,0,0,0.6)] ring-1 ring-white/[0.04] transition-all duration-300 group-hover:-translate-y-0.5 group-hover:shadow-[0_24px_48px_-20px_rgba(0,0,0,0.7)]">
            <img
              src="/compass-poster-thumbnail.png"
              alt="Body Compass poster showing green, yellow, and red food zones"
              width="398"
              height="564"
              loading="eager"
              class="block h-auto w-full"
            />
          </div>
        </a>

        <div class="md:col-start-1 md:row-start-1">
          <h1 class="mb-6 max-w-xl text-3xl font-light leading-[1.12] tracking-[-0.03em] text-accent md:text-[2.75rem]">
            Point your body in the right direction.
          </h1>

          <div class="space-y-4 text-fg/80 leading-[1.8]">
            <p>
              Most food advice contradicts itself. The Body Compass is a map.
              It sorts every common food into three zones: green, yellow, red.
            </p>
            <p>
              It traces bloating, brain fog, joint pain, or fatigue back to
              what you ate in the last 72 hours. Two paths forward: reset
              hard for 30 days, or ease in over months.
            </p>
            <p class="text-sm text-muted italic">
              The food pillar of Eat <span class="brand-dot not-italic">·</span> Move <span class="brand-dot not-italic">·</span> Meditate.
            </p>
          </div>
        </div>
      </div>
    </section>

    <section class="mt-10 animate-fade-up delay-1">
      <h2 class="mb-5 font-mono text-xs tracking-[0.25em] text-muted uppercase">What you get</h2>
      <div class="space-y-3 text-sm text-fg/70 leading-relaxed">
        <p>→ See what to eat in five seconds, not five tabs</p>
        <p>→ Trace bloating, brain fog, or fatigue back to the last 72 hours of meals</p>
        <p>→ Reset hard in 30 days, or ease in at your own pace</p>
        <p>→ Grounded in five clinical protocols (AIP · IFM · Whole30 · Wahls · FODMAP)</p>
      </div>
    </section>

    <section id="subscribe" class="newsletter-panel mt-10 animate-fade-up delay-2 rounded-[1.25rem] px-6 py-7 md:px-8 scroll-mt-20">
      <p class="mb-2 text-base font-medium text-accent">Get the poster free</p>
      <p class="mb-5 text-sm text-muted">
        Drop your email. I'll send the poster today, plus a short essay
        each week on eating, moving, and thinking clearly.
      </p>
      <p class="mb-4 text-sm text-fg/80">1,000+ readers already subscribe.</p>
      <div data-supascribe-embed-id="168170608203" data-supascribe-subscribe></div>
      <p class="mt-4 text-xs text-muted">No spam. Unsubscribe any time. One email a week.</p>
    </section>

    <script is:inline async src="https://js.supascribe.com/v1/loader/VaNM8pdlJAboZzPXnDmwNXMbiUr2.js"></script>

    <footer class="mt-20 animate-fade-up delay-3 border-t section-fade pt-8">
      <div class="flex flex-col gap-4 text-xs text-muted sm:flex-row sm:items-center sm:justify-between">
        <span>&copy; {new Date().getFullYear()} Craig Van</span>
        <div class="flex gap-6">
          <a href="https://x.com/craigvan_" target="_blank" rel="noopener" class="arrow-link transition-colors duration-300 hover:text-accent">X</a>
          <a href="/" class="transition-colors duration-300 hover:text-accent">Home</a>
        </div>
      </div>
    </footer>

  </main>
</Layout>

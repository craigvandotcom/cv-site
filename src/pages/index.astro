---
import Layout from '../layouts/Layout.astro'

const title = 'Craig Van'
const description = 'Engineer turned health obsessive. Building systems for eating, moving, and thinking clearly.'
const url = 'https://craigvan.com'
---

<Layout title={title} description={description}>
  <main class="mx-auto max-w-3xl px-6 py-20 md:py-28">

    <!-- Hero -->
    <section class="mb-24 animate-fade-up">
      <p class="mb-6 font-mono text-xs tracking-[0.25em] text-muted uppercase">eat <span class="brand-dot">·</span> move <span class="brand-dot">·</span> meditate</p>
      <h1 class="mb-6 max-w-2xl text-4xl font-light leading-[1.08] tracking-[-0.04em] text-accent md:text-[3.5rem]">
        I'm an engineer who got obsessed with<br class="hidden md:inline" /> how the human body actually works.
      </h1>
      <p class="max-w-xl text-lg leading-relaxed text-fg/78">
        Most health advice is noise. So I built systems instead —
        things I use every day, things that compound.
        Now I share what works.
      </p>
      <p class="mt-8 font-mono text-[11px] tracking-[0.22em] text-muted uppercase">Weekly cast · 10 min read or listen · 1,000+ readers</p>
    </section>

    <!-- About -->
    <section class="mb-24 animate-fade-up delay-1">
      <h2 class="mb-5 font-mono text-xs tracking-[0.25em] text-muted uppercase">About</h2>
      <div class="space-y-4 text-fg/80 leading-[1.8]">
        <p>
          I'm Craig — based in Europe, background in engineering.
          I spent years reverse-engineering how eating, moving, and stillness
          actually affect the body, then turned what I found into frameworks
          anyone can use.
        </p>
        <p>
          No hacks, no motivation required. Just honest systems
          that work on the days you don't feel like it.
        </p>
      </div>
    </section>

    <!-- Newsletter -->
    <section class="newsletter-panel mb-24 animate-fade-up delay-2 rounded-[1.25rem] px-6 py-7 md:px-8">
      <h2 class="mb-5 font-mono text-xs tracking-[0.25em] text-muted uppercase">Weekly cast</h2>
      <p class="mb-3 max-w-xl text-fg/80 leading-[1.8]">
        One email a week exploring one idea — how to eat, move, or think better.
        Short, useful, no upsells.
      </p>
      <p class="mb-8 text-sm text-muted">Join 1000+ people building calmer, more reliable health systems.</p>
      <div data-supascribe-embed-id="168170608203" data-supascribe-subscribe></div>
    </section>

    <script is:inline async src="https://js.supascribe.com/v1/loader/VaNM8pdlJAboZzPXnDmwNXMbiUr2.js"></script>

    <!-- Projects -->
    <section class="mb-24 animate-fade-up delay-3">
      <h2 class="mb-8 font-mono text-xs tracking-[0.25em] text-muted uppercase">Projects</h2>
      <div class="divide-y divide-border border-y border-border">
        <a href="https://bodycompass.app" target="_blank" rel="noopener" class="project-row group block py-6">
          <div class="flex items-start justify-between gap-6">
            <div>
              <p class="mb-3 font-mono text-[11px] tracking-[0.22em] text-muted uppercase">Free assessment</p>
              <h3 class="mb-2 text-base font-medium text-accent">Body Compass</h3>
              <p class="text-sm leading-relaxed text-muted">A free health assessment that builds you a personalised 30-day plan.</p>
            </div>
            <span class="mt-0.5 text-muted/40 transition-all duration-300 group-hover:text-accent/60 group-hover:translate-x-0.5">&#8599;</span>
          </div>
        </a>
        <a href="https://www.unsit.app" target="_blank" rel="noopener" class="project-row group block py-6">
          <div class="flex items-start justify-between gap-6">
            <div>
              <p class="mb-3 font-mono text-[11px] tracking-[0.22em] text-muted uppercase">12-week programme</p>
              <h3 class="mb-2 text-base font-medium text-accent">Unsit Your Back</h3>
              <p class="text-sm leading-relaxed text-muted">A 12-week programme to fix your back. No equipment, no guesswork.</p>
            </div>
            <span class="mt-0.5 text-muted/40 transition-all duration-300 group-hover:text-accent/60 group-hover:translate-x-0.5">&#8599;</span>
          </div>
        </a>
      </div>
    </section>

    <!-- Footer -->
    <footer class="animate-fade-up delay-4 border-t section-fade pt-10">
      <div class="flex flex-col gap-4 text-xs text-muted sm:flex-row sm:items-center sm:justify-between">
        <span>&copy; {new Date().getFullYear()} Craig Van</span>
        <div class="flex gap-6">
          <a href="https://x.com/craigvan_" target="_blank" rel="noopener" class="arrow-link transition-colors duration-300 hover:text-accent">X</a>
          <a href="https://github.com/craigvandotcom" target="_blank" rel="noopener" class="arrow-link transition-colors duration-300 hover:text-accent">GitHub</a>
        </div>
      </div>
    </footer>

  </main>
</Layout>
